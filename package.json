{
  "name": "@particle-academy/fancy-map",
  "version": "0.1.2",
  "description": "Engine-agnostic Map component for the Fancy UI suite — one <Map> API over swappable providers (OpenStreetMap via Leaflet, Google Maps), live position tracking, and a Human+ MCP bridge for cohabited human/agent maps.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-map.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-map#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-map/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./leaflet": {
      "import": {
        "types": "./dist/leaflet.d.ts",
        "default": "./dist/leaflet.js"
      },
      "require": {
        "types": "./dist/leaflet.d.cts",
        "default": "./dist/leaflet.cjs"
      }
    },
    "./google": {
      "import": {
        "types": "./dist/google.d.ts",
        "default": "./dist/google.js"
      },
      "require": {
        "types": "./dist/google.d.cts",
        "default": "./dist/google.cjs"
      }
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "react",
    "map",
    "maps",
    "leaflet",
    "openstreetmap",
    "google-maps",
    "geolocation",
    "live-tracking",
    "engine-agnostic",
    "ui"
  ],
  "peerDependencies": {
    "@googlemaps/js-api-loader": "^2.0.0",
    "leaflet": "^1.9.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "leaflet": {
      "optional": true
    },
    "@googlemaps/js-api-loader": {
      "optional": true
    }
  },
  "devDependencies": {
    "@googlemaps/js-api-loader": "^2.1.1",
    "@types/google.maps": "^3.58.1",
    "@types/leaflet": "^1.9.12",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "leaflet": "^1.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
